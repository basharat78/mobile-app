{
    "name": "vendor/nativephp-geolocation",
    "description": "Geolocation plugin for NativePHP Mobile — GPS location and permission handling",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\NativePHPGeolocation\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\NativePHPGeolocation\\GeolocationServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    }
}
